        <collision name="collision">
          <geometry><box><size>1.2 0.8 0.4</size></box></geometry>
        </collision>
        <visual name="visual">
          <geometry><box><size>1.2 0.8 0.4</size></box></geometry>
          <material><ambient>0.5 0.35 0.2 1</ambient><diffuse>0.5 0.35 0.2 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="chair1">
      <static>true</static>
      <pose>2.5 1.5 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.4 0.4 0.5</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.4 0.4 0.5</size></box></geometry>
          <material><ambient>0.25 0.25 0.25 1</ambient><diffuse>0.25 0.25 0.25 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="chair2">
      <static>true</static>
      <pose>1.5 2.5 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.4 0.4 0.5</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.4 0.4 0.5</size></box></geometry>
          <material><ambient>0.25 0.25 0.25 1</ambient><diffuse>0.25 0.25 0.25 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="chair3">
      <static>true</static>
      <pose>-3.0 -0.5 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.4 0.4 0.5</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.4 0.4 0.5</size></box></geometry>
          <material><ambient>0.25 0.25 0.25 1</ambient><diffuse>0.25 0.25 0.25 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="chair4">
      <static>true</static>
      <pose>1.2 -3.2 0.25 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.4 0.4 0.5</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.4 0.4 0.5</size></box></geometry>
          <material><ambient>0.25 0.25 0.25 1</ambient><diffuse>0.25 0.25 0.25 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="box1">
      <static>true</static>
      <pose>-3.5 3.5 0.4 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.8 1.0 0.8</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.8 1.0 0.8</size></box></geometry>
          <material><ambient>0.45 0.4 0.3 1</ambient><diffuse>0.45 0.4 0.3 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="box2">
      <static>true</static>
      <pose>3.5 3.0 0.4 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>1.0 0.7 0.8</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>1.0 0.7 0.8</size></box></geometry>
          <material><ambient>0.45 0.4 0.3 1</ambient><diffuse>0.45 0.4 0.3 1</diffuse></material>
        </visual>
      </link>
    </model>

    <model name="box3">
      <static>true</static>
      <pose>1.2 -0.2 0.3 0 0 0</pose>
      <link name="link">
        <collision name="collision"><geometry><box><size>0.8 0.8 0.6</size></box></geometry></collision>
        <visual name="visual">
          <geometry><box><size>0.8 0.8 0.6</size></box></geometry>
          <material><ambient>0.5 0.5 0.5 1</ambient><diffuse>0.5 0.5 0.5 1</diffuse></material>
        </visual>
